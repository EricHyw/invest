function renderAssetDashboard(){
  if(!assetRecords.length){
    document.getElementById('assetKpiGrid').innerHTML='<div class="empty-state"><div class="icon">💰</div><div class="text">尚無資產紀錄，請至「資產紀錄」新增</div></div>';
    document.getElementById('donutSection').style.display='none';
    document.getElementById('compareSection').style.display='none';
    return;
  }
  const dates=[...new Set(assetRecords.map(r=>r.recordDate))].sort((a,b)=>b.localeCompare(a));
  const latestDate=dates[0],prevDate=dates[1]||null;
  const latestRows=assetRecords.filter(r=>r.recordDate===latestDate);
  const prevRows=prevDate?assetRecords.filter(r=>r.recordDate===prevDate):[];
  const latest={},prev={};
  latestRows.forEach(r=>{latest[r.assetType]=(latest[r.assetType]||0)+parseFloat(r.amount||0);});
  prevRows.forEach(r=>{prev[r.assetType]=(prev[r.assetType]||0)+parseFloat(r.amount||0);});
  const latestTotal=Object.values(latest).reduce((s,v)=>s+v,0);
  const prevTotal=Object.values(prev).reduce((s,v)=>s+v,0);
  const totalChange=latestTotal-prevTotal;
  const totalChangePct=prevTotal>0?(totalChange/prevTotal*100):null;

  const typeList=[{key:'富邦現金',cls:'cash-card'},{key:'中信現金',cls:'cash2-card'},{key:'王道現金',cls:'cash3-card'},{key:'股票',cls:'stock-card'},{key:'基金',cls:'fund-card'}];
  let html=`<div class="kpi-grid">
    <div class="kpi-card total">
      <div class="kpi-label">📊 總資產（${latestDate}）</div>
      <div class="kpi-value">NT$ ${fc(latestTotal)}</div>
      ${prevDate?`<div class="kpi-change ${totalChange>=0?'pos':'neg'}">${totalChange>=0?'▲':'▼'} NT$ ${fc(Math.abs(totalChange))}${totalChangePct!==null?` (${totalChange>=0?'+':''}${totalChangePct.toFixed(1)}%)`:''}　vs ${prevDate}</div>`:'<div class="kpi-change neu">— 尚無前次比較</div>'}
    </div>`;
  typeList.forEach(({key,cls})=>{
    const val=latest[key]||0,pval=prev[key]||0,diff=val-pval;
    const pct=pval>0?(diff/pval*100):null;
    const pct_t=latestTotal>0?(val/latestTotal*100):0;
    if(!val&&!pval)return;
    html+=`<div class="kpi-card ${cls}">
      <div class="kpi-label">${key}</div>
      <div class="kpi-value">NT$ ${fc(val)}</div>
      <div class="kpi-sub">${pct_t.toFixed(1)}% 佔比</div>
      ${prevDate?`<div class="kpi-change ${diff>=0?'pos':'neg'}">${diff>=0?'▲':'▼'} NT$ ${fc(Math.abs(diff))}${pct!==null?` (${diff>=0?'+':''}${pct.toFixed(1)}%)`:''}` :'<div class="kpi-change neu">—'}</div>
    </div>`;
  });
  html+='</div>';
  document.getElementById('assetKpiGrid').innerHTML=html;

  if(latestTotal>0){document.getElementById('donutSection').style.display='';drawDonut(latest,latestTotal);}

  if(prevDate){
    document.getElementById('compareSection').style.display='';
    let rows='';
    typeList.forEach(({key})=>{const p=prev[key]||0,l=latest[key]||0,d=l-p;if(!p&&!l)return;rows+=`<tr><td>${abadge(key)}</td><td>NT$ ${fc(p)}</td><td>NT$ ${fc(l)}</td><td class="${cc(d)}">${d>=0?'+':''}NT$ ${fc(d)}</td></tr>`;});
    const td=totalChange;
    rows+=`<tr><td>合計</td><td>NT$ ${fc(prevTotal)}</td><td>NT$ ${fc(latestTotal)}</td><td class="${cc(td)}">${td>=0?'+':''}NT$ ${fc(td)}</td></tr>`;
    document.getElementById('compareContent').innerHTML=`<div style="overflow-x:auto"><table class="compare-table"><thead><tr><th>類型</th><th>${prevDate}</th><th>${latestDate}</th><th>變化</th></tr></thead><tbody>${rows}</tbody></table></div>`;
  } else { document.getElementById('compareSection').style.display='none'; }
}

function drawDonut(data,total){
  const canvas=document.getElementById('donutChart');
  const ctx=canvas.getContext('2d');
  ctx.clearRect(0,0,160,160);
  const cx=80,cy=80,r=68,inner=44;
  let start=-Math.PI/2;
  const slices=Object.entries(data).filter(([,v])=>v>0);
  slices.forEach(([key,val])=>{
    const angle=(val/total)*Math.PI*2;
    ctx.beginPath();ctx.moveTo(cx,cy);ctx.arc(cx,cy,r,start,start+angle);ctx.closePath();
    ctx.fillStyle=ASSET_COLORS[key]||'#60a5fa';ctx.fill();start+=angle;
  });
  ctx.beginPath();ctx.arc(cx,cy,inner,0,Math.PI*2);ctx.fillStyle='#0a0f1e';ctx.fill();
  ctx.fillStyle='#94a3b8';ctx.font='bold 10px sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('NT$',cx,cy-7);
  ctx.fillStyle='#f1f5f9';ctx.font='bold 12px sans-serif';
  const t=total>=1e6?(total/1e6).toFixed(1)+'M':total>=1e3?(total/1e3).toFixed(0)+'K':total.toFixed(0);
  ctx.fillText(t,cx,cy+8);
  document.getElementById('donutLegend').innerHTML=slices.map(([key,val])=>`
    <div class="legend-row">
      <div class="legend-dot" style="background:${ASSET_COLORS[key]||'#60a5fa'}"></div>
      <span style="color:#94a3b8">${key}</span>
      <span style="color:#f1f5f9;margin-left:8px">NT$ ${fc(val)}</span>
    </div>`).join('');
}

function exportCSV(){
  const filtered=getFiltered();if(!filtered.length){alert('尚無資料');return;}
  const rows=[INVEST_HEADERS,...filtered.map(r=>[r.recordTime,r.type,r.productName,r.amount,r.marketValue,r.returnAmount,r.returnRate,r.totalReturnRate])];
  const csv=rows.map(r=>r.map(c=>`"${String(c).replace(/"/g,'""')}"`).join(',')).join('\n');
  const a=document.createElement('a');a.href=URL.createObjectURL(new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8'}));
  a.download=`投資紀錄_${new Date().toLocaleDateString('zh-TW').replace(/\//g,'-')}.csv`;a.click();
}

