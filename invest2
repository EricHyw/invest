
<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>投資收益紀錄</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0f1e;
  --bg2: #0f172a;
  --bg3: rgba(255,255,255,0.04);
  --border: rgba(100,160,255,0.12);
  --text: #e2e8f0;
  --text2: #94a3b8;
  --text3: #475569;
  --blue: #60a5fa;
  --green: #34d399;
  --red: #f87171;
  --yellow: #fbbf24;
  --nav-h: 64px;
  --safe-bottom: env(safe-area-inset-bottom, 0px);
}
* { box-sizing:border-box; margin:0; padding:0; -webkit-tap-highlight-color:transparent; }
html,body { height:100%; overflow:hidden; }
body {
  background:var(--bg);
  font-family:'Noto Sans TC','PingFang TC',sans-serif;
  color:var(--text);
  display:flex; flex-direction:column;
}

/* ── Banner ── */
#banner {
  padding:9px 16px; font-size:0.72rem;
  display:flex; align-items:center; gap:8px;
  background:linear-gradient(135deg,rgba(234,179,8,0.15),rgba(234,179,8,0.05));
  border-bottom:1px solid rgba(234,179,8,0.3); color:var(--yellow);
  flex-shrink:0; transition:all 0.4s;
}
#banner.connected { background:linear-gradient(135deg,rgba(16,185,129,0.1),rgba(16,185,129,0.04)); border-bottom-color:rgba(52,211,153,0.3); color:var(--green); }
#banner .dot { width:7px;height:7px;border-radius:50%;background:var(--yellow);flex-shrink:0; }
#banner.connected .dot { background:var(--green); }

/* ── Header ── */
header {
  display:flex; align-items:center; justify-content:space-between;
  padding:0 16px; height:52px; flex-shrink:0;
  background:rgba(10,15,30,0.97);
  border-bottom:1px solid var(--border);
}
.logo { display:flex; align-items:center; gap:10px; }
.logo-icon { width:30px;height:30px;border-radius:7px;background:linear-gradient(135deg,#1d4ed8,#7c3aed);display:flex;align-items:center;justify-content:center;font-size:1rem; }
.logo-title { font-weight:700; font-size:0.95rem; color:#f1f5f9; }
.header-right { display:flex; align-items:center; gap:10px; }
.sync-pill { font-size:0.68rem; padding:3px 9px; border-radius:20px; background:var(--bg3); color:var(--text3); border:1px solid var(--border); transition:all 0.3s; }
.sync-pill.syncing { color:var(--yellow); border-color:rgba(251,191,36,0.3); }
.sync-pill.synced  { color:var(--green);  border-color:rgba(52,211,153,0.3); }
.sync-pill.error   { color:var(--red);    border-color:rgba(248,113,113,0.3); }

/* ── Scroll area ── */
#app {
  flex:1; overflow-y:auto; overflow-x:hidden;
  -webkit-overflow-scrolling:touch;
  padding-bottom:calc(var(--nav-h) + var(--safe-bottom) + 16px);
}

/* ── Bottom Nav ── */
#bottomNav {
  position:fixed; bottom:0; left:0; right:0;
  height:calc(var(--nav-h) + var(--safe-bottom));
  padding-bottom:var(--safe-bottom);
  background:rgba(10,15,30,0.97);
  border-top:1px solid var(--border);
  display:flex; align-items:stretch;
  z-index:100;
  backdrop-filter:blur(12px);
}
.nav-item {
  flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:3px; border:none; background:transparent; cursor:pointer;
  color:var(--text3); transition:color 0.2s; padding:8px 0;
  font-family:inherit;
}
.nav-item.active { color:var(--blue); }
.nav-item .nav-icon { font-size:1.3rem; line-height:1; }
.nav-item .nav-label { font-size:0.6rem; font-weight:500; letter-spacing:0.03em; }

/* ── Pages ── */
.page { display:none; padding:16px; animation:fadeUp 0.25s ease; }
.page.active { display:block; }
@keyframes fadeUp { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }

.page-title { font-size:1.1rem; font-weight:700; color:#f1f5f9; margin-bottom:16px; }
.page-label { font-size:0.65rem; color:var(--text3); letter-spacing:0.1em; margin-bottom:3px; }

/* ── Form ── */
.form-section { background:var(--bg3); border:1px solid var(--border); border-radius:14px; padding:16px; margin-bottom:14px; }
.form-section-title { font-size:0.68rem; color:var(--text3); letter-spacing:0.1em; margin-bottom:14px; }
.field { margin-bottom:14px; }
.field:last-child { margin-bottom:0; }
.field label { display:block; font-size:0.72rem; color:var(--text2); margin-bottom:6px; font-weight:500; }
.field label .sub { color:var(--text3); font-weight:400; }
.field input, .field select {
  width:100%; background:rgba(255,255,255,0.05); border:1px solid var(--border);
  border-radius:10px; padding:13px 14px; color:var(--text);
  font-size:1rem; font-family:inherit; outline:none;
  transition:border-color 0.2s;
  -webkit-appearance:none; appearance:none;
}
.field input:focus, .field select:focus { border-color:rgba(96,165,250,0.5); }
.field input.error { border-color:rgba(248,113,113,0.5); }
.field select option { background:#111827; }
.err-msg { color:var(--red); font-size:0.72rem; margin-top:5px; }
.field-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }

/* ── Buttons ── */
.btn-main {
  width:100%; padding:15px; background:linear-gradient(135deg,#1d4ed8,#2563eb);
  border:none; border-radius:12px; color:white; font-family:inherit;
  font-size:1rem; font-weight:700; cursor:pointer; transition:all 0.2s;
  box-shadow:0 4px 16px rgba(37,99,235,0.3); margin-top:4px;
}
.btn-main:active { transform:scale(0.98); }
.btn-main.success { background:linear-gradient(135deg,#059669,#10b981); }
.btn-main:disabled { opacity:0.5; }
.btn-sub {
  width:100%; padding:13px; background:transparent;
  border:1px solid var(--border); border-radius:12px;
  color:var(--text2); font-family:inherit; font-size:0.9rem;
  cursor:pointer; margin-top:8px;
}
.btn-green-full {
  padding:12px 20px; background:linear-gradient(135deg,rgba(5,150,105,0.2),rgba(16,185,129,0.1));
  border:1px solid rgba(52,211,153,0.3); color:var(--green);
  border-radius:10px; cursor:pointer; font-family:inherit; font-size:0.85rem;
  white-space:nowrap;
}
.btn-outline {
  padding:12px 16px; background:transparent; border:1px solid var(--border);
  color:var(--text2); border-radius:10px; cursor:pointer; font-family:inherit;
  font-size:0.85rem; white-space:nowrap;
}

/* ── Cards (持倉) ── */
.hold-card {
  background:var(--bg3); border:1px solid var(--border);
  border-radius:14px; padding:16px; margin-bottom:12px;
}
.hold-card-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; }
.hold-card-name { font-weight:700; font-size:1rem; color:#f1f5f9; }
.hold-card-date { font-size:0.68rem; color:var(--text3); margin-top:2px; }
.hold-stats { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
.hold-stat { background:rgba(255,255,255,0.03); border-radius:8px; padding:10px 12px; }
.hold-stat-label { font-size:0.62rem; color:var(--text3); margin-bottom:3px; }
.hold-stat-value { font-size:0.88rem; font-weight:700; }

/* 市值加總列 */
.totals-row { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:16px; }
.total-chip {
  display:flex; align-items:center; gap:8px;
  background:var(--bg3); border:1px solid var(--border);
  border-radius:10px; padding:10px 14px; flex:1; min-width:130px;
}
.total-chip.grand { border-color:rgba(96,165,250,0.25); background:rgba(96,165,250,0.05); }
.total-chip-label { font-size:0.68rem; color:var(--text3); }
.total-chip-value { font-size:0.95rem; font-weight:700; color:#f1f5f9; }
.total-chip.grand .total-chip-value { color:var(--blue); }

/* ── Filter bar ── */
.filter-bar { display:flex; align-items:center; gap:10px; margin-bottom:14px; flex-wrap:wrap; }
.filter-bar select {
  background:var(--bg3); border:1px solid var(--border);
  border-radius:10px; padding:10px 14px; color:var(--text);
  font-size:0.85rem; font-family:inherit; outline:none;
  flex:1; min-width:140px; -webkit-appearance:none;
}
.filter-bar select option { background:#111827; }
.count-tag { font-size:0.7rem; color:var(--text3); white-space:nowrap; }

/* ── Record cards (投資紀錄) ── */
.rec-card {
  background:var(--bg3); border:1px solid var(--border);
  border-radius:14px; padding:14px 16px; margin-bottom:10px;
}
.rec-card-head { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px; }
.rec-card-name { font-weight:700; font-size:0.95rem; color:#f1f5f9; }
.rec-card-date { font-size:0.68rem; color:var(--text3); margin-top:2px; }
.rec-card-actions { display:flex; gap:8px; }
.rec-grid { display:grid; grid-template-columns:1fr 1fr; gap:6px; }
.rec-item { background:rgba(255,255,255,0.02); border-radius:7px; padding:8px 10px; }
.rec-item-label { font-size:0.6rem; color:var(--text3); margin-bottom:2px; }
.rec-item-value { font-size:0.82rem; font-weight:600; }

/* 行內編輯 card */
.edit-card {
  background:rgba(37,99,235,0.07); border:1px solid rgba(96,165,250,0.25);
  border-radius:14px; padding:14px 16px; margin-bottom:10px;
}
.edit-card .field { margin-bottom:10px; }
.edit-card .field label { font-size:0.68rem; color:var(--text2); margin-bottom:4px; }
.edit-card .field input,
.edit-card .field select {
  padding:10px 12px; font-size:0.88rem; border-radius:8px;
}
.edit-btns { display:flex; gap:8px; margin-top:12px; }
.edit-btn-save {
  flex:1; padding:12px; background:linear-gradient(135deg,rgba(5,150,105,0.3),rgba(16,185,129,0.2));
  border:1px solid rgba(52,211,153,0.4); color:var(--green);
  border-radius:10px; cursor:pointer; font-family:inherit; font-size:0.9rem; font-weight:700;
}
.edit-btn-cancel {
  padding:12px 20px; background:transparent; border:1px solid var(--border);
  color:var(--text2); border-radius:10px; cursor:pointer; font-family:inherit; font-size:0.9rem;
}

/* ── Icon buttons ── */
.icon-btn {
  padding:7px 12px; border-radius:8px; border:none; cursor:pointer;
  font-size:0.78rem; font-family:inherit; transition:all 0.15s;
}
.icon-btn-edit   { background:rgba(96,165,250,0.1);  color:var(--blue); }
.icon-btn-delete { background:rgba(248,113,113,0.1); color:var(--red);  }

/* ── Badge ── */
.badge { display:inline-block; padding:3px 10px; border-radius:20px; font-size:0.72rem; font-weight:700; }
.badge.stock { background:rgba(56,189,248,0.15); color:#38bdf8; border:1px solid rgba(56,189,248,0.3); }
.badge.fund  { background:rgba(167,139,250,0.15); color:#a78bfa; border:1px solid rgba(167,139,250,0.3); }
.badge.cash  { background:rgba(52,211,153,0.12);  color:#34d399; border:1px solid rgba(52,211,153,0.25); }
.badge.cash2 { background:rgba(16,185,129,0.12);  color:#10b981; border:1px solid rgba(16,185,129,0.25); }
.badge.cash3 { background:rgba(110,231,183,0.12); color:#6ee7b7; border:1px solid rgba(110,231,183,0.25); }

/* ── KPI cards ── */
.kpi-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:16px; }
.kpi-card { background:var(--bg3); border:1px solid var(--border); border-radius:12px; padding:14px 16px; }
.kpi-card.total { grid-column:1/-1; border-color:rgba(96,165,250,0.25); background:rgba(96,165,250,0.05); }
.kpi-card.cash-card  { border-color:rgba(52,211,153,0.2); }
.kpi-card.cash2-card { border-color:rgba(16,185,129,0.2); }
.kpi-card.cash3-card { border-color:rgba(110,231,183,0.2); }
.kpi-card.stock-card { border-color:rgba(56,189,248,0.2); }
.kpi-card.fund-card  { border-color:rgba(167,139,250,0.2); }
.kpi-label { font-size:0.65rem; color:var(--text3); letter-spacing:0.08em; margin-bottom:6px; }
.kpi-value { font-size:1.15rem; font-weight:700; color:#f1f5f9; }
.kpi-sub   { font-size:0.65rem; color:var(--text3); margin-top:3px; }
.kpi-change { font-size:0.72rem; margin-top:5px; }
.kpi-change.pos { color:var(--red); }
.kpi-change.neg { color:var(--green); }
.kpi-change.neu { color:var(--text3); }

/* Donut */
.donut-wrap { display:flex; align-items:center; justify-content:center; gap:24px; flex-wrap:wrap; margin:16px 0; }
.donut-legend { display:flex; flex-direction:column; gap:9px; }
.legend-row { display:flex; align-items:center; gap:8px; font-size:0.78rem; }
.legend-dot { width:9px; height:9px; border-radius:50%; flex-shrink:0; }

/* Compare table */
.compare-table { width:100%; border-collapse:collapse; font-size:0.78rem; margin-top:10px; }
.compare-table th { padding:9px 10px; text-align:left; color:var(--text3); font-weight:600; border-bottom:1px solid var(--border); }
.compare-table td { padding:9px 10px; border-bottom:1px solid rgba(100,160,255,0.05); }
.compare-table tr:last-child td { font-weight:700; border-top:1px solid var(--border); }

/* Asset log cards */
.asset-card { background:var(--bg3); border:1px solid var(--border); border-radius:12px; padding:14px 16px; margin-bottom:10px; display:flex; align-items:center; justify-content:space-between; }
.asset-card-left .asset-amount { font-size:1rem; font-weight:700; color:#f1f5f9; margin-top:4px; }
.asset-card-left .asset-date   { font-size:0.68rem; color:var(--text3); margin-top:2px; }
.asset-card-right { display:flex; gap:8px; align-items:center; }

/* Settings */
.settings-card { background:var(--bg3); border:1px solid var(--border); border-radius:14px; padding:16px; margin-bottom:14px; }
.settings-card h3 { font-size:0.75rem; color:var(--text2); letter-spacing:0.08em; margin-bottom:14px; }
.step-list { list-style:none; }
.step-list li { padding:6px 0 6px 12px; border-left:2px solid var(--border); margin-bottom:8px; color:var(--text3); font-size:0.72rem; line-height:1.7; }
.step-list li strong { color:var(--text2); }
.step-list li code { color:var(--blue); background:rgba(96,165,250,0.08); padding:1px 5px; border-radius:3px; }
.step-list li a { color:var(--blue); text-decoration:none; }
.hint-text { font-size:0.68rem; color:var(--text3); margin-top:12px; line-height:1.8; }

/* Status */
.url-status { font-size:0.75rem; margin-top:8px; min-height:20px; }

/* Empty */
.empty-state { text-align:center; padding:48px 0; color:var(--text3); }
.empty-state .icon { font-size:2rem; margin-bottom:10px; }
.empty-state .text { font-size:0.85rem; }

/* Section divider */
.section-head { font-size:0.65rem; color:var(--text3); letter-spacing:0.1em; margin:16px 0 10px; }

/* pos/neg */
.pos { color:var(--red); }
.neg { color:var(--green); }

/* ── Modal ── */
.modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.8); z-index:300; display:flex; align-items:flex-end; justify-content:center; animation:fadeIn 0.2s; }
.modal-overlay.center { align-items:center; }
@keyframes fadeIn { from{opacity:0} to{opacity:1} }
.modal-sheet { background:var(--bg2); border-radius:20px 20px 0 0; padding:20px 20px calc(20px + var(--safe-bottom)); width:100%; max-width:480px; animation:slideUp 0.25s ease; }
@keyframes slideUp { from{transform:translateY(100%)} to{transform:translateY(0)} }
.modal-sheet h3 { font-size:1rem; font-weight:700; color:#f1f5f9; margin-bottom:8px; text-align:center; }
.modal-sheet p  { font-size:0.82rem; color:var(--text2); margin-bottom:20px; text-align:center; line-height:1.6; }
.modal-btns { display:flex; gap:10px; }
.modal-btns .btn-danger { flex:1; padding:14px; background:linear-gradient(135deg,#dc2626,#ef4444); border:none; border-radius:12px; color:white; font-family:inherit; font-size:1rem; font-weight:700; cursor:pointer; }
.modal-btns .btn-cancel-m { flex:1; padding:14px; background:var(--bg3); border:1px solid var(--border); border-radius:12px; color:var(--text2); font-family:inherit; font-size:1rem; cursor:pointer; }

@media(min-width:768px){
  #app { max-width:760px; margin:0 auto; }
  #bottomNav { max-width:760px; left:50%; transform:translateX(-50%); }
  .field-row { grid-template-columns:1fr 1fr; }
  .kpi-grid { grid-template-columns:1fr 1fr 1fr; }
}
</style>
</head>
<body>

<div id="banner"><div class="dot"></div><span id="bannerText">⚙️ 請至「設定」貼上 Apps Script 網址</span></div>

<header>
  <div class="logo">
    <div class="logo-icon">📈</div>
    <div class="logo-title">投資收益</div>
  </div>
  <div class="header-right">
    <div class="sync-pill" id="syncPill">未連線</div>
    <div style="font-size:0.72rem;color:var(--text3)">投資 <span id="recordCount" style="color:var(--blue);font-weight:700">0</span></div>
  </div>
</header>

<div id="app">

  <!-- ══ 新增投資 ══ -->
  <div class="page active" id="page-input">
    <div class="page-label">新增紀錄</div>
    <div class="page-title">投資報酬明細</div>
    <div class="form-section">
      <div class="field-row">
        <div class="field"><label>紀錄日期</label><input type="date" id="recordTime"></div>
        <div class="field"><label>投資類型</label>
          <select id="investType"><option value="股票">股票</option><option value="基金">基金</option></select>
        </div>
      </div>
      <div class="field">
        <label>投資產品名稱</label>
        <input type="text" id="productName" placeholder="例：台積電 2330">
        <div class="err-msg" id="err-productName"></div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>投資金額</label>
          <input type="number" id="amount" placeholder="0" inputmode="numeric" oninput="autoCalc()">
          <div class="err-msg" id="err-amount"></div>
        </div>
        <div class="field">
          <label>市值</label>
          <input type="number" id="marketValue" placeholder="0" inputmode="numeric" oninput="autoCalc()">
          <div class="err-msg" id="err-marketValue"></div>
        </div>
      </div>
      <div class="field-row">
        <div class="field"><label>投報金額 <span class="sub">自動</span></label><input type="number" id="returnAmount" placeholder="0" inputmode="numeric"></div>
        <div class="field"><label>投報率 % <span class="sub">自動</span></label><input type="number" id="returnRate" placeholder="0.00" inputmode="decimal"></div>
      </div>
      <div class="field"><label>含息投報率 %</label><input type="number" id="totalReturnRate" placeholder="含息後總報酬率" inputmode="decimal"></div>
    </div>
    <button class="btn-main" id="submitBtn" onclick="submitRecord()">儲存紀錄</button>
    <button class="btn-sub" onclick="clearForm()">清除</button>
  </div>

  <!-- ══ 最新持倉 ══ -->
  <div class="page" id="page-summary">
    <div class="page-label">持倉總覽</div>
    <div class="page-title">最新持倉</div>
    <div class="filter-bar">
      <select id="filterSummaryType" onchange="renderSummary()">
        <option value="">全部類型</option>
        <option value="股票">股票</option>
        <option value="基金">基金</option>
      </select>
      <span class="count-tag" id="summaryCountTag"></span>
    </div>
    <div class="totals-row" id="summaryTotals"></div>
    <div id="summaryContent"><div class="empty-state"><div class="icon">📊</div><div class="text">尚無資料</div></div></div>
  </div>

  <!-- ══ 投資紀錄 ══ -->
  <div class="page" id="page-history">
    <div class="page-label">歷史查詢</div>
    <div class="page-title">投資紀錄</div>
    <div class="filter-bar">
      <select id="filterProduct" onchange="renderHistory()"><option value="">全部產品</option></select>
      <span class="count-tag" id="resultCount"></span>
      <button class="btn-green-full" id="refreshBtn" onclick="loadRecords()">↻ 載入</button>
      <button class="btn-outline" onclick="exportCSV()">↓ CSV</button>
    </div>
    <div id="historyContent"><div class="empty-state"><div class="icon">📋</div><div class="text">尚無歷史紀錄</div></div></div>
  </div>

  <!-- ══ 總資產 ══ -->
  <div class="page" id="page-assets">
    <div class="page-label">資產概覽</div>
    <div class="page-title">總資產</div>
    <div id="assetKpiGrid"><div class="empty-state"><div class="icon">💰</div><div class="text">尚無資產紀錄</div></div></div>
