<script>
// ══ 狀態 ══
const INVEST_HEADERS=['紀錄日期','投資類型','投資產品名稱','投資金額','市值','投報金額','投報率(%)','含息投報率(%)'];
const ASSET_COLORS={'富邦現金':'#34d399','中信現金':'#10b981','王道現金':'#6ee7b7','股票':'#38bdf8','基金':'#a78bfa'};
let records=[], assetRecords=[];
let editingId=null, editingAssetId=null;
let pendingDelId=null, pendingDelType=null;
let SCRIPT_URL='https://script.google.com/macros/s/AKfycbxz-oGUojQuVQmMJD5ksArD8Gb3l89qohJPbk4dveSq_cugV74kGSP_qoPeCg3AbNnT/exec';

window.onload=()=>{
  const n=new Date(); n.setMinutes(n.getMinutes()-n.getTimezoneOffset());
  const today=n.toISOString().slice(0,10);
  document.getElementById('recordTime').value=today;
  document.getElementById('assetDate').value=today;
  document.getElementById('cfg-scriptUrl').value=SCRIPT_URL;
  if(SCRIPT_URL){setBanner(true);setSyncPill('synced','已連線');}
};

// ══ 導覽 ══
function goPage(name,btn){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  btn.classList.add('active');
  document.getElementById('app').scrollTop=0;
  if(name==='summary')renderSummary();
  if(name==='history')renderHistory();
  if(name==='assets'){if(!assetRecords.length)loadAssets();else renderAssetDashboard();}
  if(name==='assetLog'){if(!assetRecords.length)loadAssets();else renderAssetLog();}
  if(name==='settings')document.getElementById('cfg-scriptUrl').value=SCRIPT_URL;
}

// ══ 設定 & API ══
async function saveAndTest(){
  const url=document.getElementById('cfg-scriptUrl').value.trim();
  if(!url.startsWith('https://script.google.com')){setUrlStatus('error','請填入正確的網址');return;}
  setUrlStatus('pending','⏳ 測試中…');
  try{
    const res=await fetch(url+'?action=load');
    const data=await res.json();
    if(data.error)throw new Error(data.error);
    SCRIPT_URL=url; localStorage.setItem('investScriptUrl',SCRIPT_URL);
    setUrlStatus('ok','✓ 連線成功！已儲存。');
    setBanner(true); setSyncPill('synced','已連線');
    if(data.rows)applyRows(data.rows);
  }catch(e){setUrlStatus('error','✗ '+e.message);}
}
function setUrlStatus(t,m){const c=t==='ok'?'#34d399':t==='error'?'#f87171':'#fbbf24';document.getElementById('urlStatus').innerHTML=`<span style="color:${c}">${m}</span>`;}
async function apiGet(action){const res=await fetch(SCRIPT_URL+'?action='+action);const d=await res.json();if(d.error)throw new Error(d.error);return d;}
async function apiPost(payload){const res=await fetch(SCRIPT_URL,{method:'POST',body:JSON.stringify(payload)});const d=await res.json();if(d.error)throw new Error(d.error);return d;}

// ══ 投資 ══
async function loadRecords(){
  if(!SCRIPT_URL){alert('請先設定連線');return;}
  const btn=document.getElementById('refreshBtn');
  btn.disabled=true;btn.textContent='⏳';setSyncPill('syncing','載入中…');
  try{const d=await apiGet('load');applyRows(d.rows||[]);setSyncPill('synced','已同步');}
  catch(e){setSyncPill('error','失敗');alert(e.message);}
  btn.disabled=false;btn.textContent='↻ 載入';
}
function applyRows(rows){
  records=[...rows].reverse().map((r,i)=>({...r,_id:i}));
  document.getElementById('recordCount').textContent=records.length;
  updateFilterOpts(); renderHistory(); renderSummary();
}
function updateFilterOpts(){
  const sel=document.getElementById('filterProduct'),cur=sel.value;
  const names=[...new Set(records.map(r=>r.productName).filter(Boolean))].sort();
  sel.innerHTML='<option value="">全部產品</option>'+names.map(n=>`<option${n===cur?' selected':''}>${n}</option>`).join('');
}
function getFiltered(){const f=document.getElementById('filterProduct').value;return f?records.filter(r=>r.productName===f):records;}

function autoCalc(){
  const a=parseFloat(document.getElementById('amount').value)||0;
  const m=parseFloat(document.getElementById('marketValue').value)||0;
  if(a>0){document.getElementById('returnAmount').value=(m-a).toFixed(2);document.getElementById('returnRate').value=(((m-a)/a)*100).toFixed(2);}
}
function clearForm(){
  ['productName','amount','marketValue','returnAmount','returnRate','totalReturnRate'].forEach(id=>{
    document.getElementById(id).value='';
    const e=document.getElementById('err-'+id);if(e)e.textContent='';
    document.getElementById(id).classList.remove('error');
  });
  document.getElementById('investType').value='股票';
  const n=new Date();n.setMinutes(n.getMinutes()-n.getTimezoneOffset());
  document.getElementById('recordTime').value=n.toISOString().slice(0,10);
}
function validateInvest(){
  let ok=true;
  [{id:'productName',msg:'請輸入產品名稱',check:v=>v.trim()!==''},
   {id:'amount',msg:'請輸入金額',check:v=>v!==''&&!isNaN(v)},
   {id:'marketValue',msg:'請輸入市值',check:v=>v!==''&&!isNaN(v)}
  ].forEach(f=>{
    const v=document.getElementById(f.id).value,e=document.getElementById('err-'+f.id);
    if(!f.check(v)){e.textContent=f.msg;document.getElementById(f.id).classList.add('error');ok=false;}
    else{e.textContent='';document.getElementById(f.id).classList.remove('error');}
  });return ok;
}
async function submitRecord(){
  if(!validateInvest())return;
  if(!SCRIPT_URL){alert('請先設定連線');return;}
  const r={recordTime:document.getElementById('recordTime').value,type:document.getElementById('investType').value,productName:document.getElementById('productName').value.trim(),amount:document.getElementById('amount').value,marketValue:document.getElementById('marketValue').value,returnAmount:document.getElementById('returnAmount').value,returnRate:document.getElementById('returnRate').value,totalReturnRate:document.getElementById('totalReturnRate').value};
  const btn=document.getElementById('submitBtn');btn.disabled=true;btn.textContent='同步中…';setSyncPill('syncing','同步中…');
  try{
    const res=await apiPost({action:'append',row:r});
    r.rowIndex=res.rowIndex;r._id=Date.now();records.unshift(r);
    document.getElementById('recordCount').textContent=records.length;
    updateFilterOpts();renderHistory();renderSummary();
    setSyncPill('synced','已同步');btn.textContent='✓ 已儲存';btn.classList.add('success');
    setTimeout(()=>{btn.textContent='儲存紀錄';btn.classList.remove('success');btn.disabled=false;},1400);
    clearForm();
  }catch(e){setSyncPill('error','失敗');alert(e.message);btn.textContent='儲存紀錄';btn.disabled=false;}
}

// 編輯
function startEdit(id){editingId=id;renderHistory();}
function cancelEdit(){editingId=null;renderHistory();}
function editAutoCalc(id){
  const a=parseFloat(document.getElementById('ei_amount_'+id).value)||0;
  const m=parseFloat(document.getElementById('ei_marketValue_'+id).value)||0;
  if(a>0){document.getElementById('ei_returnAmount_'+id).value=(m-a).toFixed(2);document.getElementById('ei_returnRate_'+id).value=(((m-a)/a)*100).toFixed(2);}
}
async function saveEdit(id){
  const r=records.find(x=>x._id===id);if(!r)return;
  const u={recordTime:document.getElementById('ei_recordTime_'+id).value,type:document.getElementById('ei_type_'+id).value,productName:document.getElementById('ei_productName_'+id).value.trim(),amount:document.getElementById('ei_amount_'+id).value,marketValue:document.getElementById('ei_marketValue_'+id).value,returnAmount:document.getElementById('ei_returnAmount_'+id).value,returnRate:document.getElementById('ei_returnRate_'+id).value,totalReturnRate:document.getElementById('ei_totalReturnRate_'+id).value};
  if(!u.productName){alert('產品名稱不可空白');return;}
  setSyncPill('syncing','儲存中…');
  try{await apiPost({action:'update',rowIndex:r.rowIndex,row:u});Object.assign(r,u);editingId=null;updateFilterOpts();renderHistory();renderSummary();setSyncPill('synced','已同步');}
  catch(e){setSyncPill('error','失敗');alert(e.message);}
}

// 刪除
function confirmDelete(id,type){
  const r=type==='invest'?records.find(x=>x._id===id):assetRecords.find(x=>x._id===id);if(!r)return;
  pendingDelId=id;pendingDelType=type;
  const lbl=type==='invest'?`「${r.productName}」投資紀錄`:`${r.recordDate}・${r.assetType}（NT$ ${fc(r.amount)}）`;
  document.getElementById('deleteModalText').innerHTML=`確定刪除 <strong style="color:#f1f5f9">${lbl}</strong>？<br>此操作無法復原。`;
  document.getElementById('confirmDeleteBtn').onclick=executeDelete;
  document.getElementById('deleteModal').style.display='flex';
}
function closeDeleteModal(){document.getElementById('deleteModal').style.display='none';pendingDelId=null;pendingDelType=null;}
async function executeDelete(){
  const id=pendingDelId,type=pendingDelType;
  const r=type==='invest'?records.find(x=>x._id===id):assetRecords.find(x=>x._id===id);
  if(!r)return;closeDeleteModal();setSyncPill('syncing','刪除中…');
  try{
    await apiPost({action:type==='invest'?'delete':'deleteAsset',rowIndex:r.rowIndex});
    if(type==='invest'){records=records.filter(x=>x._id!==id);document.getElementById('recordCount').textContent=records.length;loadRecords();}
    else{assetRecords=assetRecords.filter(x=>x._id!==id);loadAssets();}
    setSyncPill('synced','已同步');
  }catch(e){setSyncPill('error','失敗');alert(e.message);}
}
document.getElementById('deleteModal').addEventListener('click',e=>{if(e.target===document.getElementById('deleteModal'))closeDeleteModal();});

// ══ 資產 ══
async function loadAssets(){
  if(!SCRIPT_URL){alert('請先設定連線');return;}
  const btn=document.getElementById('assetRefreshBtn');
  btn.disabled=true;btn.textContent='⏳';setSyncPill('syncing','載入中…');
  try{
    const d=await apiGet('loadAssets');
    assetRecords=[...d.rows||[]].reverse().map((r,i)=>({...r,_id:i}));
    renderAssetLog();renderAssetDashboard();setSyncPill('synced','已同步');
  }catch(e){setSyncPill('error','失敗');alert(e.message);}
  btn.disabled=false;btn.textContent='↻ 載入';
}
function clearAssetForm(){
  document.getElementById('assetAmount').value='';
  document.getElementById('err-assetAmount').textContent='';
  document.getElementById('assetAmount').classList.remove('error');
  document.getElementById('assetType').value='富邦現金';
  const n=new Date();n.setMinutes(n.getMinutes()-n.getTimezoneOffset());
  document.getElementById('assetDate').value=n.toISOString().slice(0,10);
}
async function submitAsset(){
  const amt=document.getElementById('assetAmount').value;
  const e=document.getElementById('err-assetAmount');
  if(!amt||isNaN(amt)){e.textContent='請輸入有效金額';document.getElementById('assetAmount').classList.add('error');return;}
  e.textContent='';document.getElementById('assetAmount').classList.remove('error');
  if(!SCRIPT_URL){alert('請先設定連線');return;}
  const r={recordDate:document.getElementById('assetDate').value,assetType:document.getElementById('assetType').value,amount:amt};
  const btn=document.getElementById('assetSubmitBtn');btn.disabled=true;btn.textContent='同步中…';setSyncPill('syncing','同步中…');
  try{
    const res=await apiPost({action:'appendAsset',row:r});
    r.rowIndex=res.rowIndex;r._id=Date.now();assetRecords.unshift(r);
    renderAssetLog();renderAssetDashboard();
    setSyncPill('synced','已同步');btn.textContent='✓ 已新增';btn.classList.add('success');
    setTimeout(()=>{btn.textContent='新增資產';btn.classList.remove('success');btn.disabled=false;},1400);
    clearAssetForm();
  }catch(e){setSyncPill('error','失敗');alert(e.message);btn.textContent='新增資產';btn.disabled=false;}
}
function startAssetEdit(id){editingAssetId=id;renderAssetLog();}
function cancelAssetEdit(){editingAssetId=null;renderAssetLog();}
async function saveAssetEdit(id){
  const r=assetRecords.find(x=>x._id===id);if(!r)return;
  const u={recordDate:document.getElementById('ea_date_'+id).value,assetType:document.getElementById('ea_type_'+id).value,amount:document.getElementById('ea_amount_'+id).value};
  if(!u.amount||isNaN(u.amount)){alert('請輸入有效金額');return;}
  setSyncPill('syncing','儲存中…');
  try{await apiPost({action:'updateAsset',rowIndex:r.rowIndex,row:u});Object.assign(r,u);editingAssetId=null;renderAssetLog();renderAssetDashboard();setSyncPill('synced','已同步');}
  catch(e){setSyncPill('error','失敗');alert(e.message);}
}

// ══ 渲染 ══
function fc(v){const n=parseFloat(v);return isNaN(n)?'—':n.toLocaleString('zh-TW',{maximumFractionDigits:0});}
function fr(v){const n=parseFloat(v);return(isNaN(n)||v==='')?'—':(n>=0?'+':'')+n.toFixed(2)+'%';}
function fd(dt){if(!dt)return'—';return new Date(dt+'T00:00:00').toLocaleDateString('zh-TW');}
function bdg(t){return`<span class="badge ${t==='股票'?'stock':'fund'}">${t}</span>`;}
function abadge(t){const m={'富邦現金':'cash','中信現金':'cash2','王道現金':'cash3','股票':'stock','基金':'fund'};return`<span class="badge ${m[t]||'fund'}">${t}</span>`;}
function cc(v){return parseFloat(v)>=0?'pos':'neg';}

function renderSummary(){
  const map={};
  for(const r of records)if(!map[r.productName]||new Date(r.recordTime)>new Date(map[r.productName].recordTime))map[r.productName]=r;
  const f=document.getElementById('filterSummaryType').value;
  let latest=Object.values(map).sort((a,b)=>new Date(b.recordTime)-new Date(a.recordTime));

  // 市值加總
  const allLatest=Object.values(map);
  const typeGroups={};
  allLatest.forEach(r=>{typeGroups[r.type]=(typeGroups[r.type]||0)+parseFloat(r.marketValue||0);});
  const grandTotal=Object.values(typeGroups).reduce((s,v)=>s+v,0);
  const types=f?[f]:Object.keys(typeGroups).sort();
  let totHtml=types.map(t=>`
    <div class="total-chip">
      ${bdg(t)}
      <div><div class="total-chip-label">市值</div><div class="total-chip-value">NT$ ${fc(typeGroups[t]||0)}</div></div>
    </div>`).join('');
  if(!f&&types.length>1){
    totHtml+=`<div class="total-chip grand">
      <span style="font-size:0.72rem;color:var(--blue);font-weight:700">合計</span>
      <div><div class="total-chip-label">市值</div><div class="total-chip-value">NT$ ${fc(grandTotal)}</div></div>
    </div>`;
  }
  document.getElementById('summaryTotals').innerHTML=totHtml;

  if(f) latest=latest.filter(r=>r.type===f);
  document.getElementById('summaryCountTag').textContent=latest.length?`${latest.length} 筆`:'';
  const el=document.getElementById('summaryContent');
  if(!latest.length){el.innerHTML='<div class="empty-state"><div class="icon">📊</div><div class="text">'+(Object.keys(map).length?'無符合條件的持倉':'尚無資料')+'</div></div>';return;}
  el.innerHTML=latest.map(r=>`
    <div class="hold-card">
      <div class="hold-card-head">
        <div><div style="margin-bottom:4px">${bdg(r.type)}</div><div class="hold-card-name">${r.productName}</div><div class="hold-card-date">${fd(r.recordTime)}</div></div>
      </div>
      <div class="hold-stats">
        <div class="hold-stat"><div class="hold-stat-label">投資金額</div><div class="hold-stat-value">NT$ ${fc(r.amount)}</div></div>
        <div class="hold-stat"><div class="hold-stat-label">市值</div><div class="hold-stat-value">NT$ ${fc(r.marketValue)}</div></div>
        <div class="hold-stat"><div class="hold-stat-label">投報金額</div><div class="hold-stat-value ${cc(r.returnAmount)}">${parseFloat(r.returnAmount)>=0?'+':''}NT$ ${fc(r.returnAmount)}</div></div>
        <div class="hold-stat"><div class="hold-stat-label">投報率</div><div class="hold-stat-value ${cc(r.returnRate)}">${fr(r.returnRate)}</div></div>
        <div class="hold-stat"><div class="hold-stat-label">含息投報率</div><div class="hold-stat-value ${cc(r.totalReturnRate)}">${r.totalReturnRate?fr(r.totalReturnRate):'—'}</div></div>
      </div>
    </div>`).join('');
}

function renderHistory(){
  const filtered=getFiltered();
  document.getElementById('resultCount').textContent=filtered.length?`${filtered.length} 筆`:'';
  const el=document.getElementById('historyContent');
  if(!filtered.length){el.innerHTML='<div class="empty-state"><div class="icon">📋</div><div class="text">'+(records.length?'無符合條件紀錄':'尚無歷史紀錄')+'</div></div>';return;}
  el.innerHTML=filtered.map(r=>{
    const id=r._id;
    if(editingId===id)return`
      <div class="edit-card">
        <div class="field-row">
          <div class="field"><label>日期</label><input class="field input" type="date" id="ei_recordTime_${id}" value="${(r.recordTime||'').slice(0,10)}" style="padding:10px 12px;font-size:0.88rem;border-radius:8px;width:100%;background:rgba(255,255,255,0.05);border:1px solid var(--border);color:var(--text);font-family:inherit;outline:none"></div>
